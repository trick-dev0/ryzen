<section id="container">
  <div class="container-cards-beneficios">
    {% content_for 'blocks' %}
  </div>
</section>


{% stylesheet %}
  #container {
    display: flex;
    justify-content: center;
  }

  .container-cards-beneficios {
    max-width: 1220px;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  @media (max-width: 1023px) {
    .container-cards-beneficios {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "uvps",
    "settings": [],
    "blocks": [
      {
        "type": "card-home-item"
      }
    ],
    "presets": [
      {
        "name": "UVP Preset",
        "blocks": [
          {
            "type": "card-home-item",
            "settings": {
              "title_card": "title test preset",
              "description_card": "Descrição de exemplo"
            }
          }
        ]
      }
    ]
  }
{% endschema %}