<div class="minha-secao">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.text }}</p>
</div>

{% schema %}
{
  "name": "Minha Seção",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Título da Seção"
    }
  ],
  "presets": [
    {
      "name": "Minha Seção"
    }
  ]
}
{% endschema %}